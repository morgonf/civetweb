+/****************************************************************************/
+/* OPENSSL 3.0 API FUNCTIONAL TEST                                          */
+/****************************************************************************/
+
+#if defined(OPENSSL_API_3_0) && !defined(NO_SSL)
+#include <openssl/opensslv.h>
+#include <openssl/crypto.h>
+
+static int
+tls3_request_handler(struct mg_connection *conn, void *cbdata)
+{
+	(void)cbdata;
+	mg_printf(conn,
+	          "HTTP/1.1 200 OK\r\n"
+	          "Content-Type: text/plain\r\n"
+	          "Content-Length: 14\r\n"
+	          "Connection: close\r\n\r\n"
+	          "OpenSSL 3 OK\n");
+	return 200;
+}
+
+START_TEST(test_tls_openssl3)
+{
+	struct mg_context *ctx;
+	struct mg_callbacks callbacks;
+	const char *OPTIONS[8];
+	int opt_idx = 0;
+	const char *ssl_cert = locate_ssl_cert();
+	struct mg_connection *client_conn;
+	const struct mg_response_info *client_ri;
+	char client_err[256];
+	char client_data[256];
+	int client_res;
+	unsigned long ossl_ver;
+
+	/* Runtime: verify we are running OpenSSL 3.x */
+	ossl_ver = OpenSSL_version_num();
+	ck_assert_uint_ge(ossl_ver, (unsigned long)0x30000000L);
+
+	ck_assert_uint_ne(mg_check_feature(MG_FEATURES_SSL), 0u);
+	ck_assert(ssl_cert != NULL);
+
+	memset((void *)OPTIONS, 0, sizeof(OPTIONS));
+	OPTIONS[opt_idx++] = "listening_ports";
+	OPTIONS[opt_idx++] = "8093s";
+	OPTIONS[opt_idx++] = "ssl_certificate";
+	OPTIONS[opt_idx++] = ssl_cert;
+	ck_assert_int_le(opt_idx, (int)(sizeof(OPTIONS) / sizeof(OPTIONS[0])));
+
+	memset(&callbacks, 0, sizeof(callbacks));
+	callbacks.log_message = log_msg_func;
+
+	ctx = test_mg_start(&callbacks, NULL, OPTIONS, __LINE__);
+	ck_assert(ctx != NULL);
+
+	mg_set_request_handler(ctx, "/tls3check", tls3_request_handler, NULL);
+
+	test_sleep(1);
+
+	memset(client_err, 0, sizeof(client_err));
+	client_conn = mg_connect_client("127.0.0.1", 8093, 1,
+	                                client_err, sizeof(client_err));
+	ck_assert_str_eq(client_err, "");
+	ck_assert(client_conn != NULL);
+
+	mg_printf(client_conn,
+	          "GET /tls3check HTTP/1.0\r\nHost: localhost\r\n\r\n");
+	client_res = mg_get_response(client_conn, client_err,
+	                             sizeof(client_err), 10000);
+	ck_assert_int_gt(client_res, 0);
+	ck_assert_str_eq(client_err, "");
+
+	client_ri = mg_get_response_info(client_conn);
+	ck_assert(client_ri != NULL);
+	ck_assert_int_eq(client_ri->status_code, 200);
+
+	memset(client_data, 0, sizeof(client_data));
+	mg_read(client_conn, client_data, sizeof(client_data) - 1);
+	ck_assert(strstr(client_data, "OpenSSL 3 OK") != NULL);
+
+	mg_close_connection(client_conn);
+	test_mg_stop(ctx, __LINE__);
+}
+END_TEST
+#endif /* OPENSSL_API_3_0 && !NO_SSL */
+
