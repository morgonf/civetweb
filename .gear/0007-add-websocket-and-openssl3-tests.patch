+/****************************************************************************/
+/* WEBSOCKET BASIC TEST                                                     */
+/****************************************************************************/
+
+#if defined(USE_WEBSOCKET)
+
+static const char *ws_basic_welcome = "ws-welcome";
+static const char *ws_basic_pong = "ws-pong";
+static const char *ws_basic_done = "ws-done";
+
+static int
+ws_basic_connect(const struct mg_connection *conn, void *udata)
+{
+	(void)conn;
+	(void)udata;
+	return 0;
+}
+
+static void
+ws_basic_ready(struct mg_connection *conn, void *udata)
+{
+	(void)udata;
+	mg_lock_connection(conn);
+	mg_websocket_write(conn, MG_WEBSOCKET_OPCODE_TEXT,
+	                   ws_basic_welcome, strlen(ws_basic_welcome));
+	mg_unlock_connection(conn);
+}
+
+static int
+ws_basic_data(struct mg_connection *conn, int bits, char *data,
+              size_t data_len, void *udata)
+{
+	(void)bits;
+	(void)udata;
+
+	if (data_len == 7 && !memcmp(data, "ws-ping", 7)) {
+		mg_lock_connection(conn);
+		mg_websocket_write(conn, MG_WEBSOCKET_OPCODE_TEXT,
+		                   ws_basic_pong, strlen(ws_basic_pong));
+		mg_unlock_connection(conn);
+	} else if (data_len == 6 && !memcmp(data, "ws-bye", 6)) {
+		mg_lock_connection(conn);
+		mg_websocket_write(conn, MG_WEBSOCKET_OPCODE_TEXT,
+		                   ws_basic_done, strlen(ws_basic_done));
+		mg_unlock_connection(conn);
+		return 0;
+	}
+	return 1;
+}
+
+static void
+ws_basic_close(const struct mg_connection *conn, void *udata)
+{
+	(void)conn;
+	(void)udata;
+}
+
+struct ws_basic_client_data {
+	char *data;
+	size_t len;
+	int closed;
+};
+
+static int
+ws_basic_client_data_cb(struct mg_connection *conn, int flags, char *data,
+                        size_t data_len, void *user_data)
+{
+	struct ws_basic_client_data *cd = (struct ws_basic_client_data *)user_data;
+	(void)conn;
+	(void)flags;
+	free(cd->data);
+	cd->data = (char *)malloc(data_len + 1);
+	ck_assert(cd->data != NULL);
+	memcpy(cd->data, data, data_len);
+	cd->data[data_len] = '\0';
+	cd->len = data_len;
+	return 1;
+}
+
+static void
+ws_basic_client_close_cb(const struct mg_connection *conn, void *user_data)
+{
+	struct ws_basic_client_data *cd = (struct ws_basic_client_data *)user_data;
+	(void)conn;
+	cd->closed = 1;
+}
+
+START_TEST(test_websocket_basic)
+{
+	struct mg_context *ctx;
+	struct mg_callbacks callbacks;
+	const char *OPTIONS[6];
+	int opt_idx = 0;
+	struct mg_connection *ws_conn;
+	struct ws_basic_client_data cd = {NULL, 0, 0};
+	char ebuf[256];
+	int i;
+
+	memset((void *)OPTIONS, 0, sizeof(OPTIONS));
+	OPTIONS[opt_idx++] = "listening_ports";
+	OPTIONS[opt_idx++] = "8092";
+	ck_assert_int_le(opt_idx, (int)(sizeof(OPTIONS) / sizeof(OPTIONS[0])));
+
+	memset(&callbacks, 0, sizeof(callbacks));
+	callbacks.log_message = log_msg_func;
+
+	ctx = test_mg_start(&callbacks, NULL, OPTIONS, __LINE__);
+	ck_assert(ctx != NULL);
+
+	ck_assert_uint_ne(mg_check_feature(MG_FEATURES_WEBSOCKET), 0u);
+
+	mg_set_websocket_handler(ctx, "/ws",
+	                         ws_basic_connect,
+	                         ws_basic_ready,
+	                         ws_basic_data,
+	                         ws_basic_close,
+	                         NULL);
+
+	test_sleep(1);
+
+	ws_conn = mg_connect_websocket_client("127.0.0.1", 8092, 0,
+	                                      ebuf, sizeof(ebuf),
+	                                      "/ws", NULL,
+	                                      ws_basic_client_data_cb,
+	                                      ws_basic_client_close_cb,
+	                                      &cd);
+	ck_assert(ws_conn != NULL);
+	ck_assert_str_eq(ebuf, "");
+
+	/* Wait for welcome from ready_handler (mg_set_websocket_handler) */
+	for (i = 0; i < 30 && cd.data == NULL; i++)
+		test_sleep(1);
+	ck_assert(cd.data != NULL);
+	ck_assert_str_eq(cd.data, ws_basic_welcome);
+	free(cd.data);
+	cd.data = NULL;
+
+	/* Ping -> pong: mg_websocket_client_write / mg_websocket_write */
+	mg_websocket_client_write(ws_conn, MG_WEBSOCKET_OPCODE_TEXT,
+	                          "ws-ping", 7);
+	for (i = 0; i < 30 && cd.data == NULL; i++)
+		test_sleep(1);
+	ck_assert(cd.data != NULL);
+	ck_assert_str_eq(cd.data, ws_basic_pong);
+	free(cd.data);
+	cd.data = NULL;
+
+	/* Bye -> done: data_handler returns 0 to close the connection */
+	mg_websocket_client_write(ws_conn, MG_WEBSOCKET_OPCODE_TEXT,
+	                          "ws-bye", 6);
+	for (i = 0; i < 30 && cd.data == NULL; i++)
+		test_sleep(1);
+	ck_assert(cd.data != NULL);
+	ck_assert_str_eq(cd.data, ws_basic_done);
+	free(cd.data);
+	cd.data = NULL;
+
+	mg_close_connection(ws_conn);
+	test_sleep(1);
+
+	test_mg_stop(ctx, __LINE__);
+}
+END_TEST
+#endif /* USE_WEBSOCKET */
+
